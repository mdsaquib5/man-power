generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model Lead {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  fullName    String
  email       String   @unique
  phone       String
  companyName String?
  message     String?
  createdAt   DateTime @default(now())
}

model Application {
  id               String   @id @default(auto()) @map("_id") @db.ObjectId
  fullName         String
  email            String   @unique
  phone            String
  jobProfile       String
  currentSalary    Float?
  indianExperience Float?
  gulfExperience   Float?
  resumeName       String?
  resumeMime       String?
  resumeBase64     String?
  createdAt        DateTime @default(now())
}
